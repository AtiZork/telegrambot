# Copy to .env and fill in values.
# DATABASE_URL: PostgreSQL connection string.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/divergence

# Telegram Bot token from @BotFather (required for sending alerts).
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Path to admin-editable YAML config (relative to project root).
CONFIG_PATH=config/config.yaml

# Log level: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO
